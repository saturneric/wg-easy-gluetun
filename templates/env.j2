# [[ NOTE ]]

# ==== VPN / Gluetun Basic Configuration ====
VPN_SERVICE_PROVIDER=[[ vpn.service_provider ]]
VPN_TYPE=[[ vpn.type ]]
WIREGUARD_ENDPOINT_IP=[[ vpn.wireguard.endpoint_ip ]]
WIREGUARD_ENDPOINT_PORT=[[ vpn.wireguard.endpoint_port ]]
WIREGUARD_PUBLIC_KEY=[[ vpn.wireguard.public_key ]]
WIREGUARD_PRIVATE_KEY=[[ vpn.wireguard.private_key ]]
WIREGUARD_PRESHARED_KEY=[[ vpn.wireguard.preshared_key ]]
WIREGUARD_ADDRESSES=[[ vpn.wireguard.addresses ]]
SERVER_REGIONS=[[ vpn.server_regions ]]
SERVER_COUNTRIES=[[ vpn.server_countries ]]
FIREWALL_OUTBOUND_SUBNETS=[[ firewall_subnets_str ]]

# ==== DNS Configuration ====
DNS_UPSTREAM_RESOLVER_TYPE=plain
DNS_UPSTREAM_PLAIN_ADDRESSES=[[ adguard_ipv4 ]]:53

# ==== WG-Easy Basic Configuration ====
HOST=[[ wg_easy.host ]]
INSECURE=[[ wg_easy.insecure | bool_str ]]
DISABLE_IPV6=[[ wg_easy.disable_ipv6 | bool_str ]]

# Initial setup configuration
INIT_ENABLED=[[ wg_easy.init.enabled | bool_str ]]
INIT_USERNAME=[[ wg_easy.init.username ]]
INIT_PASSWORD=[[ wg_easy.init.password ]]
INIT_HOST=[[ wg_easy.init.public_host ]]
INIT_PORT=[[ wg_easy.wireguard_port ]]
INIT_IPV4_CIDR=[[ wg_easy.init.ipv4_cidr ]]
INIT_IPV6_CIDR=[[ wg_easy.init.ipv6_cidr ]]
INIT_DNS=[[ adguard_ipv4 ]]

# ==== HTTP Proxy ====
HTTPPROXY=[[ "on" if wg_easy.http_proxy.enabled else "off" ]]
HTTPPROXY_STEALTH=[[ "on" if wg_easy.http_proxy.stealth else "off" ]]
